#: data/com.github.AppManager.metainfo.xml:6
#: data/com.github.AppManager.metainfo.xml:8
msgid "Arnis Kemlers"
msgstr ""

#: data/com.github.AppManager.metainfo.xml:9
msgid "Drag-and-drop AppImage installer for GNOME"
msgstr "Installateur d'AppImage pour GNOME par glisser-déposer"

#: data/com.github.AppManager.metainfo.xml:35
msgid "AppManager lets you install or uninstall AppImages with a familiar drag-and-drop workflow inspired by macOS. It handles desktop integration, icon extraction, executable bits, and Nautilus context menus."
msgstr "AppManager vous permet d'installer ou de désinstaller des AppImages grâce à un processus familier de glisser-déposer inspiré de macOS. Il gère l'intégration au bureau, l'extraction d'icônes, les bits exécutables et les menus contextuels Nautilus."

#: data/com.github.AppManager.metainfo.xml:47
msgid "Initial preview with drag-and-drop installs, dual install modes, Nautilus menus, and preferences UI."
msgstr "Aperçu initial avec installations par glisser-déposer, deux modes d'installation, menus Nautilus et interface utilisateur des préférences."

#: data/com.github.AppManager.metainfo.xml:48
msgid "Added optional background update checks powered by the XDG Background portal. Users grant permission on first launch, can pick an interval, and receive a notification when updates are detected."
msgstr "Ajout de vérifications facultatives des mises à jour en arrière-plan grâce au portail XDG Background. Les utilisateurs accordent l'autorisation lors du premier lancement, peuvent choisir un intervalle et reçoivent une notification lorsque des mises à jour sont détectées."

