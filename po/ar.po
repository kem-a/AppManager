#: data/com.github.AppManager.metainfo.xml:6
#: data/com.github.AppManager.metainfo.xml:8
msgid "Arnis Kemlers"
msgstr "ارنيس كيميلر"

#: data/com.github.AppManager.metainfo.xml:9
msgid "Drag-and-drop AppImage installer for GNOME"
msgstr "أداة تثبيت AppImage بالسحب والإسقاط لـ GNOME"

#: data/com.github.AppManager.metainfo.xml:35
msgid "AppManager lets you install or uninstall AppImages with a familiar drag-and-drop workflow inspired by macOS. It handles desktop integration, icon extraction, executable bits, and Nautilus context menus."
msgstr "يتيح لك AppManager تثبيت AppImages أو إلغاء تثبيته باستخدام سير عمل سحب وإفلات مألوف مستوحى من نظام التشغيل macOS. فهو يتعامل مع تكامل سطح المكتب واستخراج الأيقونات والبتات القابلة للتنفيذ وقوائم سياق Nautilus."

