msgstr "Hình thu nhỏ hình ảnh ứng dụng"

#: src/windows/preferences_window.vala:208
msgid "Install appimage-thumbnailer to generate thumbnails for AppImages"
msgstr "Cài đặt appimage-thumbnailer để tạo hình thu nhỏ cho AppImages"

