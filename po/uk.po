msgstr "Застосувати токен"

#: src/windows/preferences_window.vala:247
#: src/windows/preferences_window.vala:266
msgid "GitHub token saved"
msgstr "GitHub токен збережено"

#: src/windows/preferences_window.vala:253
msgid "Clear token"
msgstr "Очистити токен"

#: src/windows/preferences_window.vala:257
msgid "GitHub token cleared"
msgstr "GitHub токен очищено"

#: src/windows/preferences_window.vala:273
msgid "Test token"
msgstr "Перевірити токен"

#: src/windows/preferences_window.vala:274
msgid "Verify your token works and check rate limit status"
msgstr "Перевірте працездатність токена та обмеження запитів"

#: src/windows/preferences_window.vala:278
msgid "Test"
msgstr "Перевірити"

#: src/windows/preferences_window.vala:287
msgid "Testing…"
msgstr "Перевірка…"

#: src/windows/preferences_window.vala:302
msgid "Create a token on GitHub"
msgstr "Створити токен на GitHub"

#: src/windows/preferences_window.vala:303
msgid "Fine-grained token with read-only public repo access is sufficient"
msgstr ""
"Досить детального токена з доступом до публічного репо лише для читання"

#: src/windows/preferences_window.vala:360
msgid "Select Installation Directory"
msgstr "Виберіть каталог встановлення"

#: src/windows/preferences_window.vala:427
msgid "Invalid Path"
msgstr "Недійсний шлях"

#: src/windows/preferences_window.vala:437
msgid "Installation directory updated"
msgstr "Оновлено каталог встановлення"

#: src/windows/preferences_window.vala:447
msgid "Move Installed Apps?"
msgstr "Перемістити встановлені програми?"

#: src/windows/preferences_window.vala:448
#, c-format
msgid ""
"This will move %d installed app(s) to the new location. This may take a "
"while depending on the size of your apps."
msgstr ""
"Це перемістить %d встановлені програми в нове розташування. Це може зайняти "
"деякий час залежно від розміру ваших програм."

#: src/windows/preferences_window.vala:451
msgid "Move Apps"
msgstr "Перемістити додатки"

#: src/windows/preferences_window.vala:483
msgid "Moving Apps…"
msgstr "Переміщення програм…"

#: src/windows/preferences_window.vala:483
msgid "Please wait while your apps are being moved."
msgstr "Будь ласка, зачекайте, поки ваші програми переміщуються."

#: src/windows/preferences_window.vala:520
msgid "Apps moved successfully"
msgstr "Програми успішно переміщено"

#: src/windows/preferences_window.vala:522
msgid "Migration Failed"
msgstr "Помилка міграції"

#: src/windows/preferences_window.vala:522
msgid "Unknown error occurred"
msgstr "Сталася невідома помилка"

#: src/windows/preferences_window.vala:540
msgid "OK"
msgstr "Ок"

#: src/windows/preferences_window.vala:580
msgid "Authentication failed — token is invalid or expired"
msgstr "Помилка автентифікації — токен недійсний або прострочений"

#: src/windows/preferences_window.vala:582
msgid "Access forbidden — token lacks required permissions"
msgstr "Доступ заборонено — токен не має необхідних дозволів"

#: src/windows/preferences_window.vala:588
#, c-format
msgid "Token is valid — %s / %s requests remaining"
msgstr "Токен дійсний — залишилося %s / %s запитів"

#: src/windows/preferences_window.vala:590
msgid "Token is valid"
msgstr "Токен дійсний"

#: src/windows/preferences_window.vala:593
#, c-format
msgid "Unexpected response (%u)"
msgstr "Неочікувана відповідь (%u)"

#: src/windows/preferences_window.vala:596
#, c-format
msgid "Connection error: %s"
msgstr "Помилка підключення: %s"

